# Shared infrastructure
POSTGRES_DB=robotman_db
POSTGRES_TEST_DB=robotman_test
POSTGRES_USER=robotman
POSTGRES_PASSWORD=password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=robotman.events
RABBITMQ_URL=amqp://admin:robotmannext@rabbitmq:5672

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# Gateway
DISCORD_TOKEN=your-discord-bot-token

# API
RAILS_ENV=development
DASHBOARD_URL=http://localhost:3000
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
SESSION_COOKIE_KEY=_robotman_api_session
SESSION_COOKIE_SECURE=false

# Worker
WORKER_QUEUE=worker.queue
WORKER_ROUTING_KEY=discord.interaction.*

# Auto-response
AUTO_RESPONSE_QUEUE=auto-response.queue
AUTO_RESPONSE_ROUTING_KEY=discord.message.create

# Dashboard
DASHBOARD_API_BASE_URL=http://localhost:3001
DASHBOARD_DISCORD_OAUTH_URL=http://localhost:3001/auth/discord
INTERNAL_API_BASE_URL=http://api:3001
